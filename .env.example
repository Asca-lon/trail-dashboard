# =====================================================================
# trail-dashboard 통합 .env
#   - 백엔드(API) + DB + 수집기(collector) + 집계(processor) 전부 이 파일 하나로.
#   - .gitignore 에 잡혀 있어 커밋되지 않는다(키 유출 방지).
#   - 실제 키 두 개(PUBLIC_DATA_API_KEY, KMA_API_KEY)는 아래에 직접 채운다.
# =====================================================================

# ── 앱 모드 ───────────────────────────────────────────────────
# 1 = mock/*.json 응답 (DB 없이 동작)
# 0 = 실제 DB 조회. ← DB 테스트/운영은 0.
USE_MOCK=0

# CORS 허용 오리진 (쉼표 구분). 개발은 *, 배포 전엔 좁힐 것.
CORS_ORIGINS=*

# mock 디렉터리 (기본값 있음, 보통 손댈 필요 없음)
# MOCK_DIR=../mock

# ── 데이터베이스 ──────────────────────────────────────────────
# compose DB(trail) 단일 계정. 읽기(db.py)·쓰기(db_writer.py) 공용.
#
# ⚠️ host 는 localhost 로 둔다. 이유:
#   - 수집기·집계는 "호스트에서 python 으로" 실행 → localhost:5432 (compose 가 노출)
#   - API 컨테이너는 compose 가 environment 에서 host 를 'db' 로 덮어쓴다
# 즉 이 값은 "호스트 실행용"이고, 컨테이너용은 compose 가 알아서 바꾼다.
DATABASE_URL=postgresql://trail:trail@localhost:5432/trail

# compose db 서비스 비밀번호(POSTGRES_PASSWORD)와 반드시 일치해야 한다.
# compose 기본값이 trail 이므로 여기서 바꾸려면 양쪽을 같이 바꾼다.
POSTGRES_PASSWORD=trail

# =====================================================================
# 공공데이터포털 — 철도 운행 API (90일 백필 + 일일 적재에 필수)
# =====================================================================
PUBLIC_DATA_API_KEY=여기에_코레일_키_입력

KORail_RUN_API_URL=https://apis.data.go.kr/B551457/run/v2
MOLIT_TRAIN_API_URL=https://apis.data.go.kr/1613000/TrainInfo

# =====================================================================
# 기상청 API 허브 — 기상 특보 (필수)
# =====================================================================
KMA_API_KEY=여기에_기상청_키_입력

KMA_WRN_REG_URL=https://apihub.kma.go.kr/api/typ01/url/wrn_reg.php
KMA_WRN_DATA_URL=https://apihub.kma.go.kr/api/typ01/url/wrn_met_data.php
KMA_WRN_INF_URL=https://apihub.kma.go.kr/api/typ01/url/wrn_inf_rpt.php
KMA_WTHR_CMT_URL=https://apihub.kma.go.kr/api/typ01/url/wthr_cmt_rpt.php
